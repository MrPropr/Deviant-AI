{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Deviant-AI Private Prompt Template Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "scenario_id",
    "label",
    "dataset",
    "private_raw_text",
    "conditions"
  ],
  "properties": {
    "scenario_id": {
      "type": "string",
      "minLength": 1
    },
    "label": {
      "type": "string",
      "enum": ["harmful", "benign"]
    },
    "private_raw_text": {
      "type": "boolean"
    },
    "dataset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "config", "split", "index", "source", "category", "behavior_label"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "config": {"type": "string", "minLength": 1},
        "split": {"type": "string", "enum": ["harmful", "benign"]},
        "index": {},
        "source": {"type": "string", "minLength": 1},
        "category": {"type": "string", "minLength": 1},
        "behavior_label": {"type": "string", "minLength": 1}
      }
    },
    "conditions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["direct", "polite", "multi_turn", "polite_multi_turn"],
      "properties": {
        "direct": {"$ref": "#/$defs/condition"},
        "polite": {"$ref": "#/$defs/condition"},
        "multi_turn": {"$ref": "#/$defs/condition"},
        "polite_multi_turn": {"$ref": "#/$defs/condition"}
      }
    }
  },
  "$defs": {
    "condition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["prompt_status", "count_method", "word_count", "token_count", "turns"],
      "properties": {
        "prompt_status": {
          "type": "string",
          "enum": ["requires_manual_authoring", "ready"]
        },
        "count_method": {
          "type": "string",
          "const": "regex_v1"
        },
        "word_count": {
          "type": "integer",
          "minimum": 1
        },
        "token_count": {
          "type": "integer",
          "minimum": 1
        },
        "turns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["turn_index", "role", "content", "word_count", "token_count"],
            "properties": {
              "turn_index": {"type": "integer", "minimum": 1, "maximum": 3},
              "role": {"type": "string", "const": "user"},
              "content": {"type": "string", "minLength": 1},
              "word_count": {"type": "integer", "minimum": 1},
              "token_count": {"type": "integer", "minimum": 1}
            }
          }
        }
      }
    }
  }
}
