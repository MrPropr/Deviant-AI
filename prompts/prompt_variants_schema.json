{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Deviant-AI Prompt Variant Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "behavior_id",
    "source",
    "condition",
    "turns",
    "metadata"
  ],
  "properties": {
    "behavior_id": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "condition": {
      "type": "string",
      "enum": [
        "direct",
        "polite",
        "multi_turn",
        "polite_multi_turn"
      ]
    },
    "turns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "role",
          "content"
        ],
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "user",
              "assistant",
              "system"
            ]
          },
          "content": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "sanitized": {
          "type": "boolean"
        },
        "benign": {
          "type": "boolean"
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
